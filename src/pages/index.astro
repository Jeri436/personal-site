---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/ui/NavBar.astro';
import Hero from '../components/hero/Hero.astro';
import ProjectScrollShowcase from '../components/projects/ProjectScrollShowcase';
import Footer from '../components/ui/Footer.astro';

const rawProjects = await getCollection('projects');
const projects = rawProjects.map((entry) => ({
  title: entry.data.title,
  katakana: entry.data.katakana,
  description: entry.data.description,
  tech: entry.data.tech,
  year: entry.data.year,
  url: entry.data.url,
  github: entry.data.github,
  order: entry.data.order,
}));
---

<Layout>
  <NavBar />
  <main>
    <Hero />
    <ProjectScrollShowcase projects={projects} client:load />
  </main>
  <Footer />
</Layout>
