---
import '../styles/global.css';
import CatFollower from '../components/cat/CatFollower';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Built by Jeri — Software Engineer',
  description = 'Personal portfolio of Jeri, a software engineer building fast, purposeful web experiences.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Google Fonts: Bebas Neue + Space Grotesk + Noto Sans JP -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@300..700&family=Noto+Sans+JP:wght@700;900&display=swap"
      rel="stylesheet"
    />

  </head>
  <body>
    <slot />
    <!-- Cat follower — hidden on touch-only devices (no cursor) -->
    <div class="cat-follower-mount hidden md:block">
      <CatFollower client:load />
    </div>

    <!-- Lenis smooth scroll init -->
    <script>
      import Lenis from 'lenis';

      const lenis = new Lenis({
        duration: 1.2,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }

      requestAnimationFrame(raf);
    </script>
  </body>
</html>
