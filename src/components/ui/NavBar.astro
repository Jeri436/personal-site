---
import { url } from '../../utils/url'

---

<nav id='navbar' class='fixed top-0 left-0 right-0 z-50 border-b-3 border-transparent'>
  <div class='max-w-7xl mx-auto px-6 flex items-center h-14'>

    <a href={url('/')} class='nav-logo font-display text-charcoal text-xl tracking-widest hover:text-red-accent transition-colors duration-150'>
      BUILT BY JERI
    </a>

  </div>
</nav>

<style>
  #navbar {
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  #navbar.scrolled {
    background-color: var(--color-charcoal);
    border-color: rgba(242, 237, 228, 0.2);
  }

  #navbar.scrolled .nav-logo,
  #navbar.scrolled .nav-link {
    color: var(--color-parchment);
  }

  .nav-logo,
  .nav-link {
    transition: color 0.3s ease;
  }
</style>

<script>
  const nav = document.getElementById('navbar')!;

  function update() {
    nav.classList.toggle('scrolled', window.scrollY > 60);
  }

  window.addEventListener('scroll', update, { passive: true });
  update();
</script>
